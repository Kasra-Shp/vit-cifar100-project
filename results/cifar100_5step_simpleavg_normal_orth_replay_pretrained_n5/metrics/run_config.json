{
  "run_name": "cifar100_5step_simpleavg_normal_orth_replay_pretrained_n5",
  "model_checkpoint": "google/vit-base-patch16-224",
  "init_mode": "pretrained_imagenet",
  "num_classes": 100,
  "num_steps": 5,
  "classes_per_step": 20,
  "scratch_epochs": 15,
  "lora_epochs": 10,
  "ft_epochs": 5,
  "joint_epochs": 15,
  "lr_scratch": 5e-05,
  "lr_lora": 5e-05,
  "lr_ft": 3e-05,
  "lr_joint": 5e-05,
  "lora_r": 32,
  "lora_alpha": 64,
  "lora_dropout": 0.1,
  "target_modules": [
    "query",
    "key",
    "value"
  ],
  "variants": [
    "normal",
    "orth",
    "replay"
  ],
  "lambda_orth": 0.25,
  "replay_per_old_step": 250,
  "base_source": "imagenet_pretrained_vit",
  "rankext_new_rank_per_step": 8,
  "rankext_alpha_per_step": 16,
  "rankext_epochs": 10,
  "lr_rankext": 5e-05,
  "freeze_old_lora_ranks": true,
  "freeze_old_classifier_rows": false
